# Chrome remote debugging
DEBUG_HOST=127.0.0.1
DEBUG_PORT=9333
ADMIN_DEBUG_PORT=9334

# Application paths
APP_ADDRESS=http://127.0.0.1:8888
APP_PATH=C:\Program Files (x86)\AppUnderTest
INSTALLER_PATH=.\installers\app-latest.exe

# Export / reporting
EXPORT_PATH=C:\Automation\test_exports

# Database paths
DEFAULT_DB_PATH=C:\Program Files (x86)\AppUnderTest\server\application\database\default.db
QUESTIONS_DB_PATH=C:\Program Files (x86)\AppUnderTest\server\application\database\questions.db

# Application logs
LOG_PATH=C:\Program Files (x86)\AppUnderTest\server\application\storage\logs\laravel.log
TMP_PATH=C:\Program Files (x86)\AppUnderTest\server\application\storage\app\tmp

# Admin portal
ADMIN_URL=https://admin.example.com/
ADMIN_QUESTIONS_URL=https://admin.example.com/admin/questions
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=your_password_here
ADMIN_LOGIN_TIMEOUT_MS=300000

# Feature flags
HEADLESS=false
FORCE_SKIP_OVERRIDE=false
